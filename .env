# Docker / compose
COMPOSE_PROJECT_NAME=bybitbot
CONTAINER_NAME=bybitbot
DOTNET_VERSION=8.0
PROJECT_PATH=BybitBot.csproj
APP_DLL=BybitBot.dll

# Runtime
DOTNET_ENVIRONMENT=Production
TZ=Europe/Moscow
LOG_LEVEL=Information

# Bybit
BYBIT_TESTNET=true
BYBIT_API_BASE_URL=https://api-testnet.bybit.com
BYBIT_WS_PUBLIC_URL=wss://stream-testnet.bybit.com/v5/public/linear
BYBIT_WS_PRIVATE_URL=wss://stream-testnet.bybit.com/v5/private
BYBIT_RECV_WINDOW=5000
BYBIT_API_KEY=change_me
BYBIT_API_SECRET=change_me
